# Production base domain (subdomains: employee, admin)
APP_URL=https://employee.bymarketingonly.com
VITE_BASE_DOMAIN=bymarketingonly.com

# Real account passwords (REQUIRED in production — set in Render Environment)
SEED_ADMIN_EMAIL=admin@bymarketingonly.com
SEED_ADMIN_NAME=House of Kaala Admin
SEED_ADMIN_PASSWORD=

SEED_MANAGER_EMAIL=manager@bymarketingonly.com
SEED_MANAGER_NAME=HR Manager
SEED_MANAGER_PASSWORD=

SEED_EMPLOYEE_EMAIL=employee@bymarketingonly.com
SEED_EMPLOYEE_NAME=Team Member
SEED_EMPLOYEE_PASSWORD=

# Optional: Gemini AI for Kaala AI assistant
GEMINI_API_KEY=

# Email notifications (SMTP — Gmail, Hostinger, or any SMTP provider)
# Without these, in-app notifications still work; emails are skipped.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hr@bymarketingonly.com
SMTP_PASS=
SMTP_FROM=hr@bymarketingonly.com
SMTP_FROM_NAME=House of Kaala HR

# Persistent storage
# Hostinger VPS: data is stored in /var/lib/kaala-hrms/data automatically (no DATABASE_URL needed)
# Render only: set DATABASE_URL or data wipes on redeploy (Neon/Supabase free tier works)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Server
NODE_ENV=production
PORT=3000
TZ=Asia/Kolkata